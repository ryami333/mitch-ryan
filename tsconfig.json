{
  "compilerOptions": {
    "esModuleInterop": true,
    "outDir": ".tscache",
    "incremental": true,
    "jsx": "preserve",
    "strict": true,
    "lib": ["dom", "es6"],
    "allowJs": true,
    "checkJs": true,
    "skipLibCheck": true,
    "noEmit": true,
    "module": "esnext",
    "moduleResolution": "bundler",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "types": ["node"],
    "plugins": [
      {
        "name": "next"
      }
    ]
  },
  "include": ["src/**/*", "next-env.d.ts", ".next/types/**/*.ts"],
  "exclude": ["node_modules"]
}
