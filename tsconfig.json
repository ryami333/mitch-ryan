{
  "compilerOptions": {
    "esModuleInterop": true,
    "outDir": ".tscache",
    "incremental": true,
    "target": "ES2022",
    "jsx": "react-jsx",
    "strict": true,
    "lib": ["DOM", "DOM.Iterable", "ES2022"],
    "allowJs": true,
    "checkJs": true,
    "skipLibCheck": true,
    "noEmit": true,
    "module": "ESNext",
    "moduleResolution": "bundler",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "types": ["node", "vite/client"]
  },
  "include": ["src/**/*", "vite.config.ts"],
  "exclude": ["node_modules", ".output", ".nitro", ".tscache"]
}
